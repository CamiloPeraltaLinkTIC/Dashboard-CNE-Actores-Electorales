# Dashboard Unificado CNE / AE — plantilla de entorno
# Copia este archivo a .env.local y completa los valores reales.

# DB_ANALYTICS (parrilla AE/CNE, analytics GA4)
NEXT_PUBLIC_DB_ANALYTICS_URL=
NEXT_PUBLIC_DB_ANALYTICS_ANON_KEY=

# DB_ESTRATEGIA (prensa, rrss, eventos, mesa de ayuda)
# También aloja el Supabase Auth (usuarios, roles y perfiles del dashboard).
NEXT_PUBLIC_DB_ESTRATEGIA_URL=
NEXT_PUBLIC_DB_ESTRATEGIA_ANON_KEY=
# Service role de estrategia: requerido para la Admin API (CRUD de usuarios).
# NUNCA exponer en el cliente (sin prefijo NEXT_PUBLIC_).
DB_ESTRATEGIA_SERVICE_ROLE_KEY=

# DB_CONTENT (parrilla genérica)
NEXT_PUBLIC_DB_CONTENT_URL=
NEXT_PUBLIC_DB_CONTENT_ANON_KEY=

# Auth (LEGADO — login por contraseña compartida). Reemplazado por Supabase Auth
# (login por usuario/email). Conservar solo si se deja un bootstrap de emergencia.
DASHBOARD_PASSWORD=
VIEWER_PASSWORD=

# Google Analytics 4
GA_PROPERTY_ID=
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=

# Hootsuite (RRSS CNE — registro de cuentas conectadas por red)
# Genera el refresh token visitando /api/auth/hootsuite y autorizando la cuenta CNE.
HOOTSUITE_CLIENT_ID=
HOOTSUITE_CLIENT_SECRET=
CNE_HOOTSUITE_REFRESH_TOKEN=
# Opcional (cuenta Actores): ACTORES_HOOTSUITE_REFRESH_TOKEN=

# Métricas de redes (RRSS CNE) — Hootsuite no expone métricas, se usan APIs nativas:
# YouTube: API key gratis de Google Cloud con "YouTube Data API v3" habilitada.
GOOGLE_API_KEY=
# Facebook/Instagram (opcional): Page Access Tokens por cuenta, JSON { "<pageOrIgId>": "<token>" }
META_PAGE_TOKENS=
